{# This is the full content of _includes/note.html #}

{% extends "base.njk" %}

{% block content %}
  <article>
    <h1>{{ title }}</h1>
    
    {# This is the magic variable that renders your Markdown content #}
    {{ content | safe }}

    {# Here is where you could add the backlinks later if you want #}
    {% if backlinks and backlinks.length > 0 %}
      <div class="backlinks">
        <h3>Linked Here</h3>
        <ul>
          {% for link in backlinks %}
            <li><a href="{{ link.url | url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}
  </article>
{% endblock %}